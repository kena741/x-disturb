rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users: own-doc writes; authenticated reads so phone login can resolve
    // existing accounts (get by id + single-doc phone queries).
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;

      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Admin profile: any signed-in user can read/write their own profile.
    match /admin_profile/{adminId} {
      allow read, write: if isSignedIn();
    }

    // Phone → userId index for O(1) registered-user checks.
    match /phone_index/{phone} {
      allow get: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /referral_codes/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && request.query.limit <= 1;
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /referrals/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Catalog data: any signed-in user can read active plans / zones.
    match /subscription_plans/{planId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /silent_zones/{zoneId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Payment intents are created/updated by the backend; clients only watch
    // their own pending → verified/failed status.
    match /payment_intents/{txRef} {
      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /zone_activities/{activityId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }
  }
}
