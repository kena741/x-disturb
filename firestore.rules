rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // USERS COLLECTION
    match /users/{userId} {
      allow read: if request.auth != null;
      // Enforce schema for users
      allow write: if request.auth != null 
                   && request.resource.data.keys().hasAll(['email', 'displayName', 'role'])
                   && request.resource.data.email is string
                   && request.resource.data.displayName is string;
    }

    // ADMIN PROFILE COLLECTION
    match /admin_profile/{adminId} {
      allow read, write: if request.auth != null;
    }

    // ZONE ACTIVITIES COLLECTION
    match /zone_activities/{activityId} {
      allow read: if request.auth != null;
      // Enforce schema for zone activities based on your types/zone-activity.ts
      allow write: if request.auth != null 
                   && request.resource.data.keys().hasAll(['userID', 'userName', 'zoneID', 'zoneName', 'activity', 'timestamp', 'coordinates'])
                   && request.resource.data.activity in ['Entered Zone', 'Exited Zone', 'Inside Zone']
                   && request.resource.data.coordinates.keys().hasAll(['latitude', 'longitude'])
                   && request.resource.data.coordinates.latitude is number
                   && request.resource.data.coordinates.longitude is number;
    }

    // METRICS / REVENUES COLLECTION
    match /revenues/{revenueId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.data.keys().hasAll(['categoryName', 'revenue', 'targetRevenue'])
                   && request.resource.data.revenue is number
                   && request.resource.data.targetRevenue is number;
    }

    // ENTRIES / TREND DATA
    match /entries_trend/{entryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.data.keys().hasAll(['date', 'count'])
                   && request.resource.data.count is number;
    }

    match /referral_codes/{referralId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // add schema enforcement here if needed
    }

    // SILENT ZONES COLLECTION
    match /silent_zones/{zoneId} {
      allow read, write: if request.auth != null;
    }

    // PAYMENTS COLLECTION
    match /payments/{paymentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Optional: restrict write if needed
    }
  }
}
